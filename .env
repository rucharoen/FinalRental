# BASE
EXPO_PUBLIC_RENTAL_BASE_URL=https://finalrental.onrender.com
EXPO_PUBLIC_API_BASE_URL=https://finalrental.onrender.com/api

# AUTH (ลบ /api ออกเพราะมีใน BASE แล้ว)
EXPO_PUBLIC_AUTH_REGISTER=/auth/register
EXPO_PUBLIC_AUTH_SEND_OTP=/auth/request-otp
EXPO_PUBLIC_AUTH_VERIFY_OTP=/auth/verify-otp
EXPO_PUBLIC_AUTH_LOGIN=/auth/login
EXPO_PUBLIC_AUTH_LOGIN_GOOGLE=/auth/google/callback
EXPO_PUBLIC_AUTH_LOGIN_LINE=/auth/line/callback
EXPO_PUBLIC_AUTH_LOGIN_FACEBOOK=/auth/facebook/callback

# KYC
EXPO_PUBLIC_UPLOAD_KYC=/upload-kyc

# CHAT
EXPO_PUBLIC_CHAT_SEND_MESSAGE=/chat/send
EXPO_PUBLIC_CHAT_HISTORY=/chat/history/{CHAT_ID}
EXPO_PUBLIC_CHAT_LIST_BY_USER=/chat/list/{USER_ID}
EXPO_PUBLIC_CHAT_BOOKING_SUMMARY=/chat/summary/{CHAT_ID}

# AUTO / INTERVAL
EXPO_PUBLIC_AUTO_REFUND_TRIGGER=/interval/trigger

# BANK / WALLET / MONEY
EXPO_PUBLIC_BANK_LINK_ACCOUNT=/money/bank/add
EXPO_PUBLIC_WITHDRAW_REQUEST=/money/withdraw/request
EXPO_PUBLIC_ADMIN_APPROVE_WITHDRAW=/money/admin/approve

# PAYMENT
EXPO_PUBLIC_PAYMENT_NOTIFICATION=/payments
EXPO_PUBLIC_ADMIN_CONFIRM_PAYMENT=/payments/{PAYMENT_ID}/admin-verify

# PRODUCT
EXPO_PUBLIC_CREATE_PRODUCT=/products
EXPO_PUBLIC_GET_OWN_PRODUCTS=/products/me
EXPO_PUBLIC_UPDATE_PRODUCT=/products/{PRODUCT_ID}
EXPO_PUBLIC_TOGGLE_RENT_STATUS=/products/{PRODUCT_ID}/toggle
EXPO_PUBLIC_GET_PRODUCTS_BY_SHOP=/products/shop/{SHOP_ID}
EXPO_PUBLIC_GET_PRODUCTS_BY_USER=/products/user/{USER_ID}

# BOOKING / RENTAL
EXPO_PUBLIC_CREATE_BOOKING=/products/user/{USER_ID}
EXPO_PUBLIC_APPROVE_RENTAL=/rentals/{RENTAL_ID}/owner-approve
EXPO_PUBLIC_UPDATE_RENTAL_STATUS=/rentals/{RENTAL_ID}/status

# WALLET
EXPO_PUBLIC_GET_WALLET_BALANCE=/wallet/balance
EXPO_PUBLIC_GET_WALLET_HISTORY=/wallet/transactions


# REVIEW
EXPO_PUBLIC_CREATE_PRODUCT_REVIEW=/reviews/product/{PRODUCT_ID}
EXPO_PUBLIC_GET_PRODUCT_REVIEWS=/reviews/product/{PRODUCT_ID}


# SHOP
EXPO_PUBLIC_CREATE_SHOP=/shops
EXPO_PUBLIC_GET_ALL_SHOPS=/shops
EXPO_PUBLIC_GET_SHOP_BY_ID=/shops/{SHOP_ID}